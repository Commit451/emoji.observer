---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/emoji-picker.css';
import emojis from '../data/emojis.json';
import { buildEmojiSlugs } from '../utils/slug';

const slugs = buildEmojiSlugs(emojis);

// Above-the-fold items render as full anchors for crawlers and no-JS users;
// the rest ship as a compact JSON blob and the inline script hydrates them.
const SSR_COUNT = 120;
const ssrItems = emojis.slice(0, SSR_COUNT).map((item, i) => ({ ...item, slug: slugs[i] }));
const lazyItems = emojis
  .slice(SSR_COUNT)
  .map((item, i) => [item.emoji, item.name, slugs[i + SSR_COUNT]]);
---

<BaseLayout>
  <div class="App">
    <header>
      <h1>emoji.observer 👀</h1>
      <p class="subtitle">Tap any emoji to copy it to your clipboard</p>
    </header>

    <div class="search-container">
      <input
        id="emoji-search"
        type="text"
        class="search-bar"
        placeholder="Search emojis..."
        autocomplete="off"
        autofocus
      />
      <button
        id="clear-search"
        class="clear-btn"
        title="Clear search"
        type="button"
        hidden
      >
        ×
      </button>
    </div>

    <div id="emoji-grid" class="emoji-grid">
      {ssrItems.map((item) => (
        <div class="emoji-item">
          <button type="button" class="emoji-copy" title={`Copy ${item.name}`}>
            <span class="emoji-char">{item.emoji}</span>
            <span class="emoji-name">{item.name}</span>
          </button>
          <a href={`/emoji/${item.slug}/`} class="emoji-details" aria-label={`Details for ${item.name}`} title="Details">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
              <circle cx="5" cy="12" r="2" /><circle cx="12" cy="12" r="2" /><circle cx="19" cy="12" r="2" />
            </svg>
          </a>
        </div>
      ))}
    </div>

    <script type="application/json" id="emoji-data" set:html={JSON.stringify(lazyItems)} />

    <div id="no-results" class="no-results" hidden>
      No emojis found for "<span id="no-results-term"></span>"
    </div>

    <div id="toast" class="toast" hidden></div>
  </div>

  <script is:inline>
    // Take over scroll restoration so the browser doesn't fight us by snapping
    // to 0 before lazy-loaded items have been appended to the grid.
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }

    const SCROLL_KEY = 'emoji-grid-scroll';

    const searchInput = document.querySelector('#emoji-search');
    const clearButton = document.querySelector('#clear-search');
    const emojiGrid = document.querySelector('#emoji-grid');
    const noResults = document.querySelector('#no-results');
    const noResultsTerm = document.querySelector('#no-results-term');
    const toast = document.querySelector('#toast');
    const dataEl = document.querySelector('#emoji-data');

    if (emojiGrid && dataEl) {
      const lazy = JSON.parse(dataEl.textContent || '[]');
      const dotsSvg =
        '<svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">' +
        '<circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg>';
      const frag = document.createDocumentFragment();
      for (const [emoji, name, slug] of lazy) {
        const wrap = document.createElement('div');
        wrap.className = 'emoji-item';

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'emoji-copy';
        btn.title = `Copy ${name}`;
        const c = document.createElement('span');
        c.className = 'emoji-char';
        c.textContent = emoji;
        const n = document.createElement('span');
        n.className = 'emoji-name';
        n.textContent = name;
        btn.appendChild(c);
        btn.appendChild(n);

        const details = document.createElement('a');
        details.href = `/emoji/${slug}/`;
        details.className = 'emoji-details';
        details.setAttribute('aria-label', `Details for ${name}`);
        details.title = 'Details';
        details.innerHTML = dotsSvg;

        wrap.appendChild(btn);
        wrap.appendChild(details);
        frag.appendChild(wrap);
      }
      emojiGrid.appendChild(frag);
    }

    // Restore scroll only after the lazy items are in the DOM, otherwise the
    // page is too short and scrollTo silently clamps to the bottom.
    const savedScroll = sessionStorage.getItem(SCROLL_KEY);
    if (savedScroll !== null) {
      window.scrollTo(0, parseInt(savedScroll, 10) || 0);
    }

    // pagehide covers regular link clicks, browser back/forward, and bfcache.
    window.addEventListener('pagehide', () => {
      sessionStorage.setItem(SCROLL_KEY, String(window.scrollY));
    });

    // Cache name/emoji per item once so the search filter doesn't re-read DOM each keystroke.
    const itemRecords = Array.from(document.querySelectorAll('.emoji-item')).map((el) => ({
      el,
      emoji: el.querySelector('.emoji-char')?.textContent ?? '',
      name: (el.querySelector('.emoji-name')?.textContent ?? '').toLowerCase(),
    }));

    let toastTimer;

    const showToast = (message) => {
      if (!toast) return;
      toast.textContent = message;
      toast.hidden = false;
      toast.classList.remove('toast-visible');
      void toast.offsetWidth;
      toast.classList.add('toast-visible');

      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.hidden = true;
        toast.classList.remove('toast-visible');
      }, 2000);
    };

    const updateFilter = () => {
      if (!searchInput || !clearButton || !emojiGrid || !noResults || !noResultsTerm) return;

      const term = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      clearButton.hidden = term.length === 0;
      document.body.classList.toggle('show-emoji-names', term.length > 0);

      for (const r of itemRecords) {
        const matches = term.length === 0 || r.name.includes(term) || r.emoji.includes(term);
        r.el.hidden = !matches;
        if (matches) visibleCount += 1;
      }

      const hasResults = visibleCount > 0;
      emojiGrid.hidden = !hasResults;
      noResults.hidden = hasResults;
      noResultsTerm.textContent = searchInput.value;
    };

    searchInput?.addEventListener('input', updateFilter);
    clearButton?.addEventListener('click', () => {
      if (!searchInput) return;
      searchInput.value = '';
      searchInput.focus();
      updateFilter();
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'f') {
        e.preventDefault();
        searchInput?.focus();
      }
    });

    document.addEventListener('click', async (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const copyBtn = target.closest('.emoji-copy');
      if (!copyBtn) return;

      const emoji = copyBtn.querySelector('.emoji-char')?.textContent ?? '';
      if (!emoji) return;

      try {
        await navigator.clipboard.writeText(emoji);
        showToast(`Copied ${emoji} to clipboard!`);
      } catch (error) {
        console.error('Failed to copy:', error);
      }
    });

    updateFilter();
  </script>
</BaseLayout>
